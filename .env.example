# mapoi docker-compose 用環境変数テンプレート
#
# 使い方:
#   cp .env.example .env
#   sed -i "s/^USER_ID=.*/USER_ID=$(id -u)/" .env
#   sed -i "s/^GROUP_ID=.*/GROUP_ID=$(id -g)/" .env
# あるいは直接生成:
#   echo "USER_ID=$(id -u)"   > .env
#   echo "GROUP_ID=$(id -g)" >> .env
#
# .env は .gitignore で除外されるため、user 環境固有の値を安全に保持できます。
# docker compose は同 dir の .env を自動で interpolation source に使います。

# Container 内 ros user の UID / GID を host に合わせる。
# bind mount ('./:/ros2_ws/src/mapoi') 経由で container から host file に書き込む操作
# (例: POI Editor Panel の Save、colcon build の install 出力等) で host UID と一致しないと
# permission denied で失敗します。
#
# host で 'id -u' / 'id -g' の値を以下に書いてください (default 1000 のままでも動く環境では設定不要)。
USER_ID=1000
GROUP_ID=1000

# 他にも ROS_DISTRO や TURTLEBOT3_MODEL も .env に保存可能 (任意):
# ROS_DISTRO=humble
# TURTLEBOT3_MODEL=burger
